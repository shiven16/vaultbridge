generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransferStatus {
  pending
  in_progress
  success
  failed
}

enum TransferSource {
  drive
  gcs
  gmail
}

model User {
  id        String   @id @default(uuid())
  googleId  String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  sourceEmail         String?
  sourceAccessToken   String?
  sourceRefreshToken  String?
  sourceExpiryDate    DateTime?

  destEmail           String?
  destAccessToken     String?
  destRefreshToken    String?
  destExpiryDate      DateTime?

  transfers Transfer[]
}

model Transfer {
  id           String         @id @default(uuid())
  userId       String
  sourceFileId String
  fileName     String
  sourceType   TransferSource @default(drive)
  status       TransferStatus @default(pending)
  error        String?
  retryCount   Int            @default(0)
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
